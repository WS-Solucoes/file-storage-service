# ==================== Desenvolvimento (Docker) ====================
# Arquivo: .env.dev
# Uso: Variáveis de ambiente para Docker Compose em desenvolvimento
# Comando: docker-compose --env-file .env.dev up -d

# --- Database (Desenvolvimento) ---
POSTGRES_PASSWORD=postgres

# --- eRH-Service ---
ERH_STORAGE_TYPE=REMOTE
FILE_STORAGE_SERVICE_URL=http://file-storage:9085
ERH_STORAGE_PATH=/app/storage

# --- File Storage Service ---
STORAGE_TYPE=MINIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=ws-documentos
MINIO_REGION=us-east-1
FILE_STORAGE_PORT=9085

# --- Domínios (HTTP em Dev) ---
WS_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:9080
COMMON_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:9080
EFROTAS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:9080
ERH_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:9080

# --- Frontend (Dev) ---
NEXT_PUBLIC_GATEWAY_URL=http://localhost:9080
NEXT_PUBLIC_FROTAS_PREFIX=/frotas
NEXT_PUBLIC_ERH_PREFIX=/erh
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_AUTH_PREFIX=/api/auth

# --- Service Discovery ---
EUREKA_SERVER_URL=http://service-discovery:9876/eureka
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
EUREKA_INSTANCE_HOSTNAME=localhost
