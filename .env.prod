# ==================== Produção ====================
# Arquivo: .env.prod
# Uso: Variáveis de ambiente para Docker Compose em produção
# Comando: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d

# --- Database (Produção) ---
POSTGRES_PASSWORD=oCV36=?CT97

# --- eRH-Service ---
ERH_STORAGE_TYPE=REMOTE
FILE_STORAGE_SERVICE_URL=http://file-storage:9085
ERH_STORAGE_PATH=/app/storage

# --- File Storage Service ---
STORAGE_TYPE=MINIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=ws-documentos
MINIO_REGION=us-east-1
FILE_STORAGE_PORT=9085

# --- Domínios (HTTPS em Produção) ---
WS_GATEWAY_ALLOWED_ORIGINS=https://wsolucoes.com,https://www.wsolucoes.com
COMMON_ALLOWED_ORIGINS=https://wsolucoes.com,https://www.wsolucoes.com
EFROTAS_ALLOWED_ORIGINS=https://wsolucoes.com,https://www.wsolucoes.com
ERH_ALLOWED_ORIGINS=https://wsolucoes.com,https://www.wsolucoes.com

# --- Frontend (Produção) ---
NEXT_PUBLIC_GATEWAY_URL=https://wsolucoes.com
NEXT_PUBLIC_FROTAS_PREFIX=/frotas
NEXT_PUBLIC_ERH_PREFIX=/erh
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_AUTH_PREFIX=/api/auth

# --- Service Discovery ---
EUREKA_SERVER_URL=http://service-discovery:9876/eureka
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
EUREKA_INSTANCE_HOSTNAME=service-discovery
